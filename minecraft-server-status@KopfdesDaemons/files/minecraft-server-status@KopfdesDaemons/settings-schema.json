{
  "layout": {
    "type": "layout",
    "pages": ["server-page", "style-page"],
    "server-page": {
      "type": "page",
      "title": "Server",
      "sections": ["server-section"]
    },
    "style-page": {
      "type": "page",
      "title": "Style",
      "sections": ["size-section", "background-section", "layout-section"]
    },
    "server-section": {
      "type": "section",
      "title": "Server",
      "keys": ["server-addresses", "refresh-interval"]
    },
    "size-section": {
      "type": "section",
      "title": "Size",
      "keys": ["scale-size", "max-height"]
    },
    "background-section": {
      "type": "section",
      "title": "Background",
      "keys": ["background-color", "hide-decorations"]
    },
    "layout-section": {
      "type": "section",
      "title": "Layout",
      "keys": ["show-header"]
    }
  },
  "scale-size": {
    "type": "scale",
    "default": 1,
    "min": 0.5,
    "max": 3,
    "step": 0.1,
    "description": "Desklet scale size"
  },
  "server-addresses": {
    "type": "list",
    "columns": [
      {
        "id": "name",
        "title": "Name",
        "type": "string"
      },
      {
        "id": "address",
        "title": "Address",
        "type": "string"
      }
    ],
    "default": []
  },
  "max-height": {
    "type": "spinbutton",
    "default": 30,
    "min": 10,
    "max": 100,
    "step": 1,
    "units": "em",
    "description": "Max height"
  },
  "background-color": {
    "type": "colorchooser",
    "default": "rgba(134, 134, 134, 0.58)",
    "description": "Background color"
  },
  "hide-decorations": {
    "type": "checkbox",
    "description": "Hide decorations",
    "default": true
  },
  "refresh-interval": {
    "type": "spinbutton",
    "default": 1,
    "min": 1,
    "max": 1000,
    "step": 1,
    "units": "minutes",
    "description": "Refresh interval"
  },
  "show-header": {
    "type": "checkbox",
    "default": true,
    "description": "Show header"
  }
}
